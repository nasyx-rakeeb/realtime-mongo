{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "cache": false,
      "inputs": ["src/**/*.ts", "test/**/*.ts"]
    },
    "lint": {
      "inputs": ["src/**/*.ts"]
    },
    "typecheck": {}
  }
}

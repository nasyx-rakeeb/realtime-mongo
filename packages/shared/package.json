{
  "name": "@realtimemongo/shared",
  "version": "0.1.0",
  "description": "Shared protocol types, Zod schemas, and VClock utilities for @realtimemongo",
  "author": "realtime-mongo contributors",
  "license": "MIT",
  "homepage": "https://github.com/nasyx-rakeeb/realtime-mongo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nasyx-rakeeb/realtime-mongo"
  },
  "bugs": {
    "url": "https://github.com/nasyx-rakeeb/realtime-mongo/issues"
  },
  "keywords": [
    "mongodb",
    "realtime",
    "websocket",
    "react",
    "firestore",
    "change-streams",
    "live-data",
    "subscription"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "provenance": "true"
  }
}
